APP_NAME="NayePankh InsightHub API"
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./data/nayepankh_insighthub.db
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
DEBUG=True

# Gemini API Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=25
