```gitignore
# Frontend / Node
node_modules/
.next/
out/
build/
dist/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
ENV/

# Environment secrets
.env
.env.*
!.env.example
!**/.env.example

# Local databases
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3

# Generated uploads and storage
uploads/
tmp/
backend/storage/
backend/artifacts/

# ML model artifacts
*.joblib
*.pkl
*.pickle

# Logs
*.log

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
```
